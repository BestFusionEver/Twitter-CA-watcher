X_BEARER_TOKEN=

# Telegram notification, recommended for VPS use
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Or use Discord instead of Telegram
DISCORD_WEBHOOK_URL=

# Set to 0 later if you want to hide timing logs.
TIMING_LOGS=1

# Set to 1 for shorter/faster alert messages.
ALERT_COMPACT=0

# Optional: send detected CA to Telegram BasedBot with your own Telegram user session.
BASEDBOT_ENABLED=0
BASEDBOT_USERNAME=based_eth_bot
BASEDBOT_SESSION=/var/lib/x-ca-watcher/basedbot.session
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
